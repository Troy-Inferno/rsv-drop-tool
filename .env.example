# Supabase (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=RSV Drop Tool <reminders@your-domain.com>

# Public site URL (used for unsubscribe links and email CTAs)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Cron + admin auth (set to a long random string)
CRON_SECRET=replace-with-long-random-string
ADMIN_EXPORT_TOKEN=replace-with-long-random-string

# Optional unsubscribe HMAC secret (defaults to CRON_SECRET if unset)
UNSUBSCRIBE_SECRET=replace-with-long-random-string

# Microsoft Clarity analytics project ID (optional)
# When set, the Clarity tracking script loads on every page.
# Get yours at https://clarity.microsoft.com → Settings → Setup → tracking code.
NEXT_PUBLIC_CLARITY_ID=
